# ─────────────────────────────────────────────
# WireGuard (wg-easy)
# ─────────────────────────────────────────────

# Your DuckDNS hostname (e.g. yourname.duckdns.org)
WG_HOST=yourname.duckdns.org

# Bcrypt hash of your wg-easy web UI password
# Generate one at: https://bcrypt.online/
# Note: use $$ instead of $ in this file to escape for Docker Compose
WG_PASSWORD_HASH=$$2a$$12$$changeme

# DNS server pushed to VPN clients
WG_DNS=1.1.1.1

# Subnet routed through the VPN (split tunnel — only VPN traffic, not all internet)
WG_ALLOWED_IPS=10.8.0.0/24

# VPN IP pool — your VM will be 10.8.0.1, clients get 10.8.0.2, .3, etc.
WG_DEFAULT_ADDRESS=10.8.0.x


# ─────────────────────────────────────────────
# Vanilla / Paper server
# ─────────────────────────────────────────────

VANILLA_VERSION=LATEST
VANILLA_INIT_MEMORY=2G
VANILLA_MAX_MEMORY=4G
VANILLA_DIFFICULTY=normal
VANILLA_MAX_PLAYERS=10
VANILLA_MOTD=Vanilla Server

# Uncomment and fill to enable whitelist:
# VANILLA_WHITELIST=YourUsername,FriendUsername
# VANILLA_OPS=YourUsername


# ─────────────────────────────────────────────
# Modded server (Forge + CurseForge)
# ─────────────────────────────────────────────

# Free API key from: https://console.curseforge.com/#/api-keys
CF_API_KEY=your-curseforge-api-key

# CurseForge modpack slug — the last part of the modpack's URL
# e.g. https://www.curseforge.com/minecraft/modpacks/all-the-mods-9 → all-the-mods-9
CF_SLUG=all-the-mods-9

# Uncomment to pin to a specific MC + Forge version (recommended for stability):
# MODDED_VERSION=1.20.1
# MODDED_FORGE_VERSION=47.3.0

MODDED_INIT_MEMORY=2G
MODDED_MAX_MEMORY=6G     # increase for heavy modpacks (300+ mods → try 8G)
MODDED_DIFFICULTY=normal
MODDED_MAX_PLAYERS=10
MODDED_MOTD=Modded Server

# Uncomment and fill to enable whitelist:
# MODDED_WHITELIST=YourUsername,FriendUsername
# MODDED_OPS=YourUsername
