# =============================================================================
# MEDIASTACK CONFIGURATION
# Edit these values before running setup.sh
# =============================================================================

# --- User / Permissions ---
# Run: `id` in your terminal to find these values
PUID=1000
PGID=1000
TZ=America/Detroit

# --- Storage Paths ---
# Where all your media and app data will live
MEDIASTACK_ROOT=/opt/mediastack

# Immich
IMMICH_DATA=${MEDIASTACK_ROOT}/immich/data
IMMICH_UPLOAD_LOCATION=${MEDIASTACK_ROOT}/immich/library
IMMICH_DB_DATA=${MEDIASTACK_ROOT}/immich/db

# Jellyfin
JELLYFIN_CONFIG=${MEDIASTACK_ROOT}/jellyfin/config
JELLYFIN_CACHE=${MEDIASTACK_ROOT}/jellyfin/cache
MEDIA_MOVIES=${MEDIASTACK_ROOT}/media/movies
MEDIA_TVSHOWS=${MEDIASTACK_ROOT}/media/tvshows
MEDIA_MUSIC=${MEDIASTACK_ROOT}/media/music

# *ARR Suite (uncomment when ready)
# RADARR_CONFIG=${MEDIASTACK_ROOT}/radarr/config
# SONARR_CONFIG=${MEDIASTACK_ROOT}/sonarr/config
# PROWLARR_CONFIG=${MEDIASTACK_ROOT}/prowlarr/config
# QBITTORRENT_CONFIG=${MEDIASTACK_ROOT}/qbittorrent/config
# DOWNLOADS=${MEDIASTACK_ROOT}/downloads

# --- Immich Database ---
DB_HOSTNAME=immich_postgres
DB_USERNAME=immich
DB_PASSWORD=change_me_please
DB_DATABASE_NAME=immich
REDIS_HOSTNAME=immich_redis

# Immich version (check https://github.com/immich-app/immich/releases)
IMMICH_VERSION=release

# --- Network Ports ---
# Change these if you have conflicts
IMMICH_PORT=2283
JELLYFIN_PORT=8096
JELLYFIN_HTTPS_PORT=8920

# *ARR Ports (uncomment when ready)
# RADARR_PORT=7878
# SONARR_PORT=8989
# PROWLARR_PORT=9696
# QBITTORRENT_PORT=8080
